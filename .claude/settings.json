      "mcp__unity-mcp__Unity_GetConsoleLogs",
      "mcp__unity-mcp__Unity_GetProjectData",
      "mcp__unity-mcp__Unity_ValidateScript",
      "mcp__unity-mcp__Unity_Grep",
      "mcp__unity-mcp__Unity_FindInFile",
      "mcp__unity-mcp__Unity_ListResources",
      "mcp__unity-mcp__Unity_ManageMenuItem"
    ]
  }
}
